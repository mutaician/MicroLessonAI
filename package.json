{
  "name": "microlesson-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "bun --watch server/index.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "bun server/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@runwayml/sdk": "^3.21.0",
    "@supabase/supabase-js": "^2.49.8",
    "hono": "^4.7.11",
    "lucide-react": "^0.511.0",
    "openai": "^5.3.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
